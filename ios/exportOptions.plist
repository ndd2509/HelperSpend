<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  HelperSpend - iOS Export Options
  Dùng cho xcodebuild -exportArchive
  Chỉnh sửa theo nhu cầu distribution (app-store, ad-hoc, development)
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <!-- Đổi thành "app-store" khi submit lên App Store -->
    <string>development</string>

    <key>teamID</key>
    <!-- Thay bằng Apple Developer Team ID của bạn -->
    <string>YOUR_TEAM_ID</string>

    <key>signingStyle</key>
    <string>automatic</string>

    <key>stripSwiftSymbols</key>
    <true/>

    <key>uploadSymbols</key>
    <true/>

    <key>compileBitcode</key>
    <false/>
</dict>
</plist>
